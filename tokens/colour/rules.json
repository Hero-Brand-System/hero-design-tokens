{
  "accessibility": {
    "standard": "WCAG 2.2 AA",
    "contrastTargets": {
      "normalText": "4.5:1",
      "largeText": "3:1",
      "uiComponents": "3:1"
    }
  },
  "usage": {
    "semanticTokensRequired": true,
    "primitiveDirectUse": {
      "allowed": false,
      "exceptions": [
        "token system definition",
        "documentation examples",
        "migration work explicitly approved by the design system owner"
      ]
    }
  },
  "allowedCombinations": [
    {
      "foreground": "color.text.primary",
      "background": "color.background.default",
      "expectedContrast": "AA"
    },
    {
      "foreground": "color.text.secondary",
      "background": "color.background.default",
      "expectedContrast": "AA"
    },
    {
      "foreground": "color.text.inverse",
      "background": "color.background.brand",
      "expectedContrast": "AA"
    },
    {
      "foreground": "color.action.primaryText",
      "background": "color.action.primary",
      "expectedContrast": "AA"
    }
  ],
  "changePolicy": {
    "pullRequestRequired": true,
    "mustInclude": [
      "change rationale",
      "impacted semantic tokens",
      "accessibility validation",
      "figma update confirmation if relevant"
    ]
  }
}
